# services/ai/.env.example - AI-specific placeholders
# Copy to services/ai/.env for local testing (do not commit!)

# Gemini API key (preferred: use OS environment instead of file)
GEMINI_API_KEY=REPLACE_WITH_YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-31-flash-lite-preview
GEMINI_TEMPERATURE=0.7
AI_CACHE_DIR=.ai_cache
AI_CACHE_TTL_HOURS=24
AI_FALLBACK_ENABLED=true

# Usage:
#   cp services/ai/.env.example services/ai/.env
#   Edit services/ai/.env to add GEMINI_API_KEY or rely on environment variables.
