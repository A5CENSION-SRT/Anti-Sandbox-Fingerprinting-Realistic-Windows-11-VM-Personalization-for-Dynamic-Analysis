# .env.example - placeholder environment variables for ARC
# Copy to .env (or set environment variables) and do NOT commit secrets to git.
# Recommended: export GEMINI_API_KEY in your environment or use a secrets manager.

# Gemini / AI settings
GEMINI_API_KEY=REPLACE_WITH_YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TEMPERATURE=0.7
AI_CACHE_DIR=.ai_cache
AI_CACHE_TTL_HOURS=24
AI_FALLBACK_ENABLED=true

# Artifact scale overrides (integers)
ARTIFACT_SCALE_DOWNLOADS=1500
ARTIFACT_SCALE_DOCUMENTS=4500
ARTIFACT_SCALE_PICTURES=750
ARTIFACT_SCALE_VIDEOS=240
ARTIFACT_SCALE_MUSIC=500
ARTIFACT_SCALE_HISTORY=7500
ARTIFACT_SCALE_SEARCH=1500
ARTIFACT_SCALE_BOOKMARKS=200

# Other settings
PROFILES_DIR=profiles/generated
TIMELINE_DAYS=90

# Usage:
#   cp .env.example .env
#   Edit .env and set GEMINI_API_KEY (or export GEMINI_API_KEY in your shell)
#   Never commit the actual .env with secrets to version control.
